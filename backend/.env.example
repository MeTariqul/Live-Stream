# =============================================================================
# SECURITY: Generate bcrypt hash for admin password
# Run: python generate_hash.py YourPassword
# Then paste the output hash here.
# =============================================================================
ADMIN_USER=admin
ADMIN_PASS_HASH=$2b$12$REPLACE_WITH_ACTUAL_BCRYPT_HASH

# =============================================================================
# Stream configuration
# =============================================================================
STREAM_KEY=mystream
HTTP_PORT=3000
RTMP_PORT=1935
HLS_PATH=./media/hls

# =============================================================================
# Session security (MANDATORY in production)
# Must be at least 64 random characters. Generate with:
# python -c "import secrets; print(secrets.token_hex(64))"
# =============================================================================
SESSION_SECRET=change-me-to-a-64-char-random-string

# =============================================================================
# Frontend origin for CORS (MANDATORY in production)
# Example: https://your-app.vercel.app
# =============================================================================
FRONTEND_ORIGIN=http://localhost:3000

# =============================================================================
# Nginx / RTMP
# =============================================================================
RTMP_PUBLIC_URL=rtmp://localhost:1935/live
FFMPEG_PATH=ffmpeg

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
