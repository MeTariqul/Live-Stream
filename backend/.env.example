# Admin credentials
ADMIN_USER=admin
ADMIN_PASS=Admin@123

# Stream configuration
STREAM_KEY=mystream
HTTP_PORT=3000
RTMP_PORT=1935

# Session secret (change in production)
SESSION_SECRET=change-me-to-a-random-string

# FFmpeg path (adjust for your OS)
FFMPEG_PATH=/usr/bin/ffmpeg

# HLS output directory (relative to project root)
HLS_DIR=./media/hls

# Frontend origin for CORS (set to your Vercel domain in production)
FRONTEND_ORIGIN=*
